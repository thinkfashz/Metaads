# ============================================
#   META ADS MANAGER — Variables de Entorno
# ============================================
# Copia este archivo como .env.local para desarrollo
# En Vercel: Settings → Environment Variables

# ----------------------------
# META / FACEBOOK API
# ----------------------------

# Token de acceso de larga duración (Long-Lived Token)
# Obtenerlo en: https://developers.facebook.com/tools/explorer
# Permisos necesarios: ads_read, ads_management, business_management
META_ACCESS_TOKEN=your_long_lived_access_token_here

# ID de tu cuenta publicitaria (formato: act_XXXXXXXXX)
# Encuéntralo en: business.facebook.com/adsmanager → URL o Configuración
META_ACCOUNT_ID=act_XXXXXXXXX

# Versión de la API de Meta a usar
META_API_VERSION=v19.0

# ----------------------------
# AI PROVIDERS (elige uno o varios)
# El endpoint /api/ai usará el proveedor seleccionado en el panel
# ----------------------------

# OpenAI — GPT-4o, GPT-4o-mini
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — Claude 3.5 Haiku / Sonnet / Opus
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — acceso a muchos modelos, incluidos gratuitos
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini — Gemini 1.5 Flash / Pro
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ----------------------------
# APP CONFIG
# ----------------------------

# Entorno: development | production
NODE_ENV=development

# Clave secreta para validar requests internos (genera una aleatoria)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=your_random_secret_key_here

# ----------------------------
# CORS (opcional)
# ----------------------------

# Dominio permitido para llamadas al API (tu dominio en Vercel)
# Ejemplo: https://meta-ads-manager.vercel.app
ALLOWED_ORIGIN=http://localhost:3000
